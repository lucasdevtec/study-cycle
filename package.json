    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.1.3",
    "sequelize": "^3.30.0"
  },
  "devDependencies": {
